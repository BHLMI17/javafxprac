<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400" prefWidth="600" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafxpractice.controllers.MainController">
   <children>
      <Label layoutX="224.0" layoutY="51.0" prefHeight="46.0" prefWidth="151.0" text="Main Page Screen" textFill="RED" />
      <Button fx:id="NSButton" layoutX="258.0" layoutY="174.0" mnemonicParsing="false" onAction="#buttonPushed" text="Next" />
      <VBox alignment="TOP_CENTER" layoutX="18.0" layoutY="219.0" prefHeight="123.0" prefWidth="233.0">
         <children>
            <TextField fx:id="Username" promptText="Enter a username" />
            <TextField fx:id="Password" promptText="Enter a password" />
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
               <children>
                  <Button fx:id="LoginButton" alignment="BOTTOM_CENTER" contentDisplay="CENTER" mnemonicParsing="false" onAction="#onLoginPushed" text="Confirm" textAlignment="CENTER" />
               </children>
            </HBox>
         </children>
      </VBox>
      <Label fx:id="ErrorLabel" layoutX="41.0" layoutY="322.0" prefHeight="63.0" prefWidth="553.0" textOverrun="WORD_ELLIPSIS" />
      <Button fx:id="ttButton" layoutX="478.0" layoutY="246.0" mnemonicParsing="false" onAction="#goToTT" text="Timetable" />
   </children>
</AnchorPane>
