<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafxpractice.controllers.TimetableController">

    <children>
        <BorderPane AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

            <center>
                <ScrollPane fx:id="timeScroll" fitToHeight="false" fitToWidth="false" pannable="true">

                    <content>
                        <!-- This is your timetable canvas -->
                        <AnchorPane fx:id="timetablePane"/>
                    </content>

                </ScrollPane>
            </center>
         <top>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
               <children>
                  <Label fx:id="mondayLabel" text="WeekLabel" />
                  <Button fx:id="AddItemButton" mnemonicParsing="false" onAction="#addItemToSchedule" text="Add New Item " />
                  <Button fx:id="pWB" mnemonicParsing="false" onAction="#previousWeek" text="Previous Week" />
                  <Button fx:id="nWB" mnemonicParsing="false" onAction="#nextWeek" text="Next Week" />
               </children>
            </HBox>
         </top>
         <right>
            <VBox fx:id="scheduleCreationBox" alignment="TOP_CENTER" disable="true" managed="false" prefHeight="200.0" prefWidth="250.0" visible="false" BorderPane.alignment="CENTER">
               <children>
                  <HBox prefHeight="100.0" prefWidth="200.0">
                     <children>
                        <Label alignment="TOP_CENTER" text="Please Enter Some Account Schedule Details" textAlignment="CENTER" wrapText="true">
                           <font>
                              <Font size="10.0" />
                           </font>
                        </Label>
                        <Button fx:id="BackButton" managed="false" mnemonicParsing="false" onAction="#closeScheduleScreen" text="Back" />
                     </children>
                  </HBox>
                  <TextField fx:id="itemName" promptText="Event Name" />
                  <Spinner fx:id="timeSpinner" />
                  <Spinner fx:id="durationSpinner" layoutX="3.0" layoutY="51.0" />
                  <DatePicker fx:id="datePicker" />
                  <Button fx:id="confirmItemButton" mnemonicParsing="false" onAction="#confirmItemAddition" text="Confirm Item" />
               </children>
            </VBox>
         </right>

        </BorderPane>
    </children>

</AnchorPane>
