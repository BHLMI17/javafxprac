<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafxpractice.controllers.TimetableController">

    <children>
        <BorderPane AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

            <center>
                <ScrollPane fx:id="timeScroll" fitToHeight="false" fitToWidth="true" pannable="true">

                    <content>
                        <!-- This is your timetable canvas -->
                        <AnchorPane fx:id="timetablePane" minHeight="0" minWidth="0" />
                    </content>

                </ScrollPane>
            </center>
         <top>
            <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
               <children>
                  <Button fx:id="AddItemButton" mnemonicParsing="false" onAction="#addItemToSchedule" text="Add New Item " />
               </children>
            </HBox>
         </top>
         <right>
            <VBox fx:id="scheduleCreationBox" alignment="TOP_CENTER" disable="true" managed="false" prefHeight="200.0" prefWidth="158.0" visible="false" BorderPane.alignment="CENTER">
               <children>
                  <Label alignment="TOP_CENTER" text="Please Enter Some Account Schedule Details" textAlignment="CENTER" wrapText="true">
                     <font>
                        <Font size="10.0" />
                     </font>
                  </Label>
                  <Button fx:id="BackButton" managed="false" mnemonicParsing="false" onAction="#closeScheduleScreen" text="Back" />
               </children>
            </VBox>
         </right>

        </BorderPane>
    </children>

</AnchorPane>
